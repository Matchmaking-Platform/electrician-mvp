# ============================================================
# 拷贝此文件为 .env (不会被提交到 git),然后按需修改各项。
# Copy this file to .env (gitignored) and adjust values.
# ============================================================

# ---- 数据库 / Database ----
# 本地 docker compose 起的 Postgres 默认用这串。
# Default DATABASE_URL for the docker-compose Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/electrician_mvp?schema=public"

# ---- NextAuth ----
# 本地开发用 http://localhost:3000;部署时改成线上域名。
NEXTAUTH_URL="http://localhost:3000"
# 生成新值:openssl rand -base64 32   (示例值见下,生产环境务必换掉)
NEXTAUTH_SECRET="REPLACE_ME_WITH_openssl_rand_base64_32"

# ---- Stripe (Test Mode) ----
# 阶段 6 接入支付时再去 https://dashboard.stripe.com/test/apikeys 取。
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Stripe CLI: `stripe listen --forward-to localhost:3000/api/stripe/webhook` 会打印这个值。
STRIPE_WEBHOOK_SECRET=""

# ---- 平台抽成 / Platform commission ----
# 0 = 免费(MVP 初期);后期改 0.15 表示 15% 抽成,改完重启即可,无需改代码。
PLATFORM_COMMISSION_RATE="0"

# ---- 文件上传 / Uploads ----
# MVP 阶段把上传文件存到本地 public/uploads/ 目录,后期可接 S3。
UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_SIZE_MB="5"

# ---- 公开站点 URL(供前端使用) ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Socket.io ----
# 独立 socket 服务端口。生产环境通常通过反向代理把 /socket.io/* 转到这里。
SOCKET_PORT="3001"
# 前端访问 socket 服务的 URL。dev 写本机端口,生产写公开域名。
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
